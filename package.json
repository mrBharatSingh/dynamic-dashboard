{
  "name": "dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:package": "npm run build && npm run package",
    "dev": "npm run build:package -- --watch --configuration development",
    "prod": "ng build --configuration production --base-href /dynamic-dashboard/ && npm run package",
    "test": "ng test",
    "package": "node packagescript.js",
    "api": "rimraf src/libs/dashboard-api/model && openapi-generator-cli generate -g typescript-angular -i src/libs/swagger.json -o src/libs/dashboard-api"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/cdk": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@katoid/angular-grid-layout": "^2.2.0",
    "@primeuix/themes": "^1.2.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/swagger-ui-express": "^4.1.8",
    "file-saver": "^2.0.5",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.7.0",
    "tsoa": "^7.0.0-alpha.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "~19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.6.2"
  }
}
